# Stalwart JMAP endpoint (admin listener, localhost on the VPS)
JMAP_URL=http://127.0.0.1:8088
MAIL_DOMAIN=hypamail.me
MAIL_HOST=mail.hypamail.me
NEXT_PUBLIC_MAIL_DOMAIN=hypamail.me

# Stalwart management admin (used only server-side for provisioning new accounts)
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASS=

# New-account storage quota in bytes (1 GiB)
ACCOUNT_QUOTA_BYTES=1073741824

# Session cookie encryption — 32+ random bytes, e.g. `openssl rand -base64 48`
SESSION_SECRET=

# Cloudflare Turnstile (signup bot protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Postgres for invite codes
DATABASE_URL=postgres://hypamail_web:CHANGEME@127.0.0.1:5432/hypamail_web
